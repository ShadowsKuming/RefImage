# Copy this file to .env and fill in your API keys

OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth (Fixed Token / invite system) ───────────────────────────────────────
# Format: token1:user_id1,token2:user_id2
# If only "token" (no colon), the token itself becomes the user_id
REFIMG_TOKENS=change-me:your_username

# Existing projects without owner_id are treated as owned by this user
DEFAULT_OWNER_ID=your_username

# Deployment: set to your server's public IP or domain
# Local:  leave commented out (defaults to localhost)
# Remote: API_BASE=http://YOUR_SERVER_IP:8000
#         ALLOWED_ORIGINS=http://YOUR_SERVER_IP:3001
# API_BASE=
# ALLOWED_ORIGINS=

# Per-user project limit (0 = unlimited)
# PROJECT_LIMIT=5

# Optional: override default model providers
# LLM_PROVIDER=openai
# VISION_PROVIDER=openai
# IMAGE_PROVIDER=openai
# SKETCH_MODEL=gpt-image-2
# FAST_LLM_MODEL=claude-haiku-4-5-20251001
